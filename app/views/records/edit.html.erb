<h1>観戦記録を編集</h1>

<% if @record.errors.any? %>
  <div>
    <p><%= @record.errors.count %>件のエラーがあります。</p>
    <ul>
      <% @record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @record do |f| %>
  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :watched_on, "観戦日" %><br>
    <%= f.date_field :watched_on %>
  </div>

  <div>
    <%= f.label :body, "感想" %><br>
    <%= f.text_area :body %>
  </div>

  <div>
    <%= f.submit "更新する" %>
  </div>
<% end %>