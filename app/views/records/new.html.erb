<h1>観戦記録を投稿</h1>

<% if @record.errors.any? %>
  <div>
    <p><%= @record.errors.count %>件のエラーがあります。</p>
    <ul>
      <% @record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @record do |f| %>
  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :watched_on, "観戦日" %><br>
    <%= f.date_field :watched_on %>
  </div>

  <div>
    <%= f.label :body, "感想" %><br>
    <%= f.text_area :body %>
  </div>

  <div>
    <%= f.label :favorite_player_ids, "応援した推し選手" %><br>

    <% if @favorite_players.any? %>
      <%= f.collection_check_boxes :favorite_player_ids, @favorite_players, :id, :name do |b| %>
        <div>
          <%= b.check_box %>
          <%= b.label %>
        </div>
      <% end %>
    <% else %>
      <p>推し選手が登録されていません。</p>
    <% end %>
  </div>

  <div>
    <%= f.submit "投稿する" %>
  </div>
<% end %>
